# Backend runtime
DOTENV_FILES=.env.local,.env
PORT=:8080
DATABASE_URL=postgres://openfga:openfga@postgres:5432/openfga?sslmode=disable
JWT_SIGNING_KEY=dev-only-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
EMAIL_CODE_TTL=10m
SMS_CODE_TTL=10m
SMS_RATE_WINDOW=10m
SMS_RESEND_INTERVAL=60s
SMS_MAX_PER_PHONE=5
SMS_MAX_PER_IP=20
PASSWORD_RESET_TTL=15m
LITELLM_BASE_URL=
LITELLM_DEFAULT_MODEL=gpt-4o-mini
LITELLM_MASTER_KEY=
LITELLM_HTTP_TIMEOUT=5s
LITELLM_DEFAULT_USER_QUOTA=10
PLATFORM_ADMIN_EMAILS=
AUTHZ_PROVIDER=memory
OPENFGA_API_URL=http://openfga:8080
OPENFGA_STORE_ID=
SMS_PROVIDER=log
ALIBABA_CLOUD_REGION_ID=cn-hangzhou
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE_REGISTER=

# Frontend runtime
VITE_API_BASE_URL=

# OpenFGA/Postgres for local compose
OPENFGA_DATASTORE_URI=postgres://openfga:openfga@postgres:5432/openfga?sslmode=disable
IMAGE_REGISTRY=docker.io
