# Required: full backend image reference in ACR
# Example: registry.cn-hangzhou.aliyuncs.com/my-namespace/ai-hermes-portal/backend:sha-abc1234
BACKEND_IMAGE=
OPENFGA_IMAGE=openfga/openfga:latest

# Optional runtime envs
HOST_PORT=8080
HOST_OPENFGA_PORT=8081

# Required: external Postgres for backend account/auth data
DATABASE_URL=postgres://user:password@your-rds-pg-host:5432/portal?sslmode=require
JWT_SIGNING_KEY=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
EMAIL_CODE_TTL=10m
PASSWORD_RESET_TTL=15m

# OpenFGA via docker compose, Postgres still external
AUTHZ_PROVIDER=openfga
OPENFGA_API_URL=http://openfga:8080
OPENFGA_DATASTORE_URI=postgres://user:password@your-rds-pg-host:5432/openfga?sslmode=require
OPENFGA_STORE_ID=
